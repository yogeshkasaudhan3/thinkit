# Base URL for API requests made from the native Android (Capacitor) build
# of Thinkit. Ignored by the web app — the web app always uses relative
# "/api/..." paths against its own origin, regardless of this value.
#
# Set this before running `pnpm run build` + `pnpm run cap:sync` for the
# Android app, to whichever backend you want the app to talk to:
#
#   Development/testing build (points at this workspace's public dev URL):
#     VITE_API_BASE_URL=https://51030ba7-b78d-49de-ad9e-63f68624f6f7-00-3k6g8du5hxeff.sisko.replit.dev
#
#   Production build (once the API server is deployed):
#     VITE_API_BASE_URL=https://your-production-domain.example
#
# Copy this file to ".env" (or ".env.production" / ".env.development") and
# fill in the value — do not commit real ".env" files.
VITE_API_BASE_URL=
